# ══════════════════════════════════════════════════════════════════════════════
# .dockerignore — Files excluded from the Docker build context
# ══════════════════════════════════════════════════════════════════════════════
#
# When `docker build` runs, Docker sends all files in the project directory
# to the Docker daemon as the "build context". Large or unnecessary files in
# the context slow down the build and can bloat the final image if accidentally
# COPYed in.
#
# This file lists patterns to exclude from that context. It uses the same
# syntax as .gitignore.
#
# Note: even if a file is listed here, it can still be referenced by name in
# a COPY instruction — Docker will simply not find it and the build will fail.
# That is intentional: it forces us to be explicit about what enters the image.
# ══════════════════════════════════════════════════════════════════════════════


# ── Source control ─────────────────────────────────────────────────────────────
# The .git directory can be hundreds of MB on a mature repo.
# It contains the entire project history — none of which is needed at runtime.
.git
# .gitignore itself is a developer tool; the container has no use for it.
.gitignore


# ── Documentation & tooling config ───────────────────────────────────────────
# Markdown files (README.md, etc.) are for humans reading the repo on GitHub.
# They add no value to the running container.
*.md

# pyproject.toml is used only by type checkers (Pyrefly, Pyright, MyPy) and
# pip tooling during local development. The container installs dependencies via
# requirements.txt directly, so pyproject.toml is not needed at runtime.
pyproject.toml


# ── Python cache ───────────────────────────────────────────────────────────────
# Bytecode and cache files are machine-generated and will be recreated inside
# the container anyway. Including them wastes build context transfer time and
# can cause confusing "stale bytecode" bugs if they were compiled on a
# different Python version.
__pycache__/     # bytecode cache directories
*.pyc            # compiled bytecode files
*.pyo            # optimised bytecode files
*.pyd            # Windows Python extension DLLs (unlikely but harmless to exclude)
.pytest_cache/   # pytest artefacts from local test runs

# Virtual environments (large, reproducible from requirements.txt)
venv/
.venv/


# ── Runtime artefacts ─────────────────────────────────────────────────────────
# The downloads/ directory holds temporary video and clip files.
# These must never be baked into the image because:
#   1. They can be very large (videos up to hundreds of MB).
#   2. They are ephemeral by design — cleaned up after each job.
#   3. Baking them in would expose potentially copyrighted content in the image.
downloads/


# ── Local environment / secrets ────────────────────────────────────────────────
# .env files contain SECRET_KEY, BOT_TOKEN, and other sensitive values.
# If included in the build context and accidentally COPYed, they would be
# embedded in the image layers and visible to anyone who pulls the image.
# Always inject secrets via environment variables at runtime, not via COPY.
.env      # standard dotenv file
.env.*    # any variant (e.g. .env.local, .env.production)


# ── Editor and OS artefacts ────────────────────────────────────────────────────
# Generated by macOS Finder, Windows Explorer, and text editors.
# They contain no useful information for the container.
.DS_Store   # macOS directory metadata
Thumbs.db   # Windows thumbnail cache
*.swp       # Vim swap files (created when a file is open in Vim)
