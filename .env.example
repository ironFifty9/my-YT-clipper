# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Environment variable template for local development
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in your real values.
# `.env` is listed in .gitignore and will never be committed.
#
#   cp .env.example .env
#
# In production (Railway / Render / Docker) set these as platform env vars —
# never ship a `.env` file in your Docker image or repository.
# ══════════════════════════════════════════════════════════════════════════════


# ── Authentication ──────────────────────────────────────────────────────────
# Required in production. Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret


# ── Redis (optional) ────────────────────────────────────────────────────────
# Set to enable the Redis-backed job store and multi-worker gunicorn support.
# Leave commented out to use the default in-memory backend (single process).
#
# Local Redis (Docker):  docker run -p 6379:6379 redis:7-alpine
# REDIS_URL=redis://localhost:6379/0


# ── Clip constraints ────────────────────────────────────────────────────────
MAX_CLIP_DURATION=3600      # max clip length in seconds   (default: 1 hour)
MAX_FILE_MB=50              # Telegram upload limit in MB  (default: 50 MB)


# ── Concurrency ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=4       # global simultaneous worker cap  (default: 4)
MAX_JOBS_PER_CHAT_DAY=5    # per-chat clips per 24-hour window (default: 5)


# ── Storage ─────────────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads      # temp download folder (default: downloads/)


# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000                   # HTTP port (default: 5000; auto-set by Railway/Render)
