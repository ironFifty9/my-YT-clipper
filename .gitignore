# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — Files and directories Git should never track
# ══════════════════════════════════════════════════════════════════════════════
#
# Git ignores anything matching these patterns. They are never committed,
# never show up in `git status`, and are not sent to GitHub/GitLab.
#
# Rule of thumb: ignore anything that is:
#   - Generated automatically (cache, compiled files, build output)
#   - Machine-specific (virtual environments)
#   - Secret (API keys, tokens, .env files)
#   - A runtime artefact (temporary downloads)
# ══════════════════════════════════════════════════════════════════════════════


# ── Python cache ───────────────────────────────────────────────────────────────
# Python writes .pyc (bytecode) and .pyo (optimised bytecode) files to speed
# up subsequent imports. They are entirely machine-generated and must never be
# committed — they contain absolute paths from the developer's machine and will
# differ on every system.
__pycache__/   # directory created automatically next to any imported .py file
*.pyc          # compiled bytecode (Python 2/3)
*.pyo          # optimised bytecode (Python 2, -O flag)


# ── Environment / secrets ──────────────────────────────────────────────────────
# .env files store sensitive values like SECRET_KEY, BOT_TOKEN, etc.
# Committing them would expose credentials in the repository history forever
# (even if deleted later, the values remain in git history).
# Set these as environment variables in Railway/Render/Heroku instead.
*.env   # any file whose name ends with .env (e.g. production.env, test.env)
.env    # the standard dotenv file name used by python-dotenv and docker-compose


# ── Test artefacts ─────────────────────────────────────────────────────────────
# Generated by pytest when running the test suite.
.pytest_cache/   # pytest's internal cache directory
htmlcov/         # HTML coverage report (generated by coverage.py --html)
.coverage        # raw coverage data file


# ── Runtime download directory ─────────────────────────────────────────────────
# The downloads/ directory holds temporary video and clip files created during
# job processing. These are ephemeral — they should never be committed because:
#   1. They can be very large (videos up to hundreds of MB).
#   2. They may contain copyrighted content.
#   3. They are cleaned up automatically after each job completes.
downloads/


# ── Virtual environments ───────────────────────────────────────────────────────
# Python virtual environments are large (50–500 MB) and entirely reproducible
# from requirements.txt. They must not be committed.
venv/    # standard venv name (python -m venv venv)
.venv/   # alternative hidden venv name used by some tools (Poetry, PDM)


# ── Python packaging artefacts ─────────────────────────────────────────────────
# Generated by setuptools / pip when building installable packages.
# Not relevant for a web application but included defensively.
*.egg-info/   # package metadata directory (created by pip install -e .)
dist/         # built distribution files (.whl, .tar.gz)
build/        # setuptools build directory


# ── Operating system files ─────────────────────────────────────────────────────
# macOS creates .DS_Store files in every directory it browses.
# These are pure metadata artefacts with no relevance to the project.
.DS_Store
